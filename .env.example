# Docker Hub 계정명 — compose 가 이미지 경로(${DOCKERHUB_USERNAME}/pinq-backend)에 사용
DOCKERHUB_USERNAME=

DB_HOST=
DB_PORT=
DB_NAME=
DB_USERNAME=
DB_PASSWORD=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
OPENAI_API_KEY=
ADMIN_SECRET=
JWT_SECRET=
# access token 만료(ms). 기본 1시간.
JWT_EXPIRATION_MS=3600000
# refresh token 만료(sec). 기본 14일.
JWT_REFRESH_EXPIRATION_SEC=1209600
ANTHROPIC_API_KEY=
# Android 앱과 동일한 구글 "웹 애플리케이션" 클라이언트 ID (ID Token aud 검증용, 필수)
GOOGLE_WEB_CLIENT_ID=
# FCM 푸시 — Firebase 콘솔 > 프로젝트 설정 > 서비스 계정 > 비공개 키(JSON) 발급 후:
#   base64 -i service-account.json | tr -d '\n'
# 미설정 시 푸시 전송만 비활성화되고 앱은 정상 기동
FIREBASE_SERVICE_ACCOUNT_BASE64=
# 신규 서버 첫 기동 시에만 update 로 설정해 스키마 생성 후 삭제 (기본 validate)
# DDL_AUTO=update

# ── HTTPS / Let's Encrypt ────────────────────────────────────────────────
# 도메인 (DuckDNS 또는 본인 소유 도메인)
DOMAIN=
# Let's Encrypt 만료 알림 수신 메일 (필수)
CERT_EMAIL=

# ── DuckDNS (무료 동적 DNS, 도메인 없을 때) ──────────────────────────────
# www.duckdns.org 에서 발급. EC2 IP 가 변하면 duckdns-update.sh 로 동기화.
DUCKDNS_SUBDOMAIN=
DUCKDNS_TOKEN=
