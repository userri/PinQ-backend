DB_HOST=
DB_PORT=
DB_NAME=
DB_USERNAME=
DB_PASSWORD=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
OPENAI_API_KEY=
ADMIN_SECRET=
JWT_SECRET=
ANTHROPIC_API_KEY=

# ── HTTPS / Let's Encrypt ────────────────────────────────────────────────
# 도메인 (DuckDNS 또는 본인 소유 도메인)
DOMAIN=
# Let's Encrypt 만료 알림 수신 메일 (필수)
CERT_EMAIL=

# ── DuckDNS (무료 동적 DNS, 도메인 없을 때) ──────────────────────────────
# www.duckdns.org 에서 발급. EC2 IP 가 변하면 duckdns-update.sh 로 동기화.
DUCKDNS_SUBDOMAIN=
DUCKDNS_TOKEN=
